# Copy to .env and fill in real values. Never commit .env.

# Random long string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# SQLAlchemy connection string. SQLite is fine for quick local testing
# (default below), but CT210 runs Postgres:
#   DATABASE_URL=postgresql+psycopg2://fpga_app:CHANGE_ME@localhost:5432/fpga_remote_lab
DATABASE_URL=sqlite:///./fpga_remote_lab.db

# SMTP settings for 2FA emails. Leave SMTP_HOST empty for local development -
# the email service logs the code to the console instead of sending it.
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_EMAIL=noreply@h-brs.de
MAIL_FROM_NAME=FPGA Remote Lab

# Lab session duration in seconds (how long a user keeps active access
# once their reservation starts).
SESSION_DURATION_SECONDS=240

# Minimum minutes of advance notice required for a scheduled reservation.
MIN_RESERVATION_ADVANCE_MINUTES=5

# How often (seconds) the background job sweeps for expired reservations
# and advances lab queues.
EXPIRY_SWEEP_INTERVAL_SECONDS=60
